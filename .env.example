# =============================================================================
# 环境变量配置模板
# =============================================================================
# 使用说明：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 修改下面的值为你的实际配置
#   3. .env 已加入 .gitignore，不会被提交到代码仓库
# =============================================================================

# 应用配置
APP_NAME=KnowledgeBase
APP_ENV=production
APP_DEBUG=false

# =============================================================================
# Jasypt 密码加密配置
# =============================================================================
# 主密钥：用于解密 YAML 中 ENC() 包裹的配置值
# ⚠️ 务必设置为自己的密钥，且不要提交到代码仓库
# 加密工具用法（在 backend 目录下执行）：
#   JAVA_HOME=$(/usr/libexec/java_home -v 17) mvn -q dependency:build-classpath -Dmdep.outputFile=/tmp/kb-cp.txt
#   $JAVA_HOME/bin/java -cp "$(cat /tmp/kb-cp.txt):target/classes" \
#     -Djasypt.encryptor.password=<你的主密钥> \
#     com.geekyous.kb.utils.JasyptEncryptUtil encrypt <要加密的明文>
JASYPT_ENCRYPTOR_PASSWORD=your-master-key-change-me

# =============================================================================
# 数据库配置（MySQL）
# =============================================================================
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=knowledge_base
DB_USERNAME=kb_user
# ⚠️ 生产环境务必修改为强密码
DB_PASSWORD=kb_password_2024
DB_ROOT_PASSWORD=root_password_2026

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# ⚠️ 生产环境务必修改为强密码
REDIS_PASSWORD=redis_password

# =============================================================================
# Elasticsearch 配置
# =============================================================================
ES_HOST=elasticsearch
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=

# =============================================================================
# JWT 配置
# =============================================================================
# ⚠️ 生产环境务必使用 256 位随机密钥
JWT_SECRET=your-secret-key-here-please-change-in-production
JWT_EXPIRATION=86400

# =============================================================================
# RSA 密码加密配置
# =============================================================================
# 私钥（PKCS8 DER Base64）：用于前后端密码加密传输。仅配置私钥，公钥由应用启动时派生。
#   - 留空 + RSA_STRICT=false（默认）→ 回退启动时随机生成（仅开发，重启换密钥）
#   - 留空 + RSA_STRICT=true          → 拒绝启动（生产强约束）
#   - 配置后                          → 持久化密钥对，重启/多实例共享同一对
# 生成命令（项目根目录，输出单行 Base64 直接粘贴到下面）：
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out /tmp/rsa_private.pem
#   openssl pkcs8 -topk8 -nocrypt -in /tmp/rsa_private.pem -outform DER | base64 | tr -d '\n'
# ⚠️ 生产环境务必设置 RSA_STRICT=true 并配置此私钥；私钥仅存 .env，不入仓库
RSA_PRIVATE_KEY=
RSA_STRICT=false

# =============================================================================
# AI 服务配置
# =============================================================================
AI_SERVICE_URL=http://ai-service:8000
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM 配置
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2
OLLAMA_EMBED_MODEL=nomic-embed-text
MOCK_MODE=false

# =============================================================================
# Qdrant 配置
# =============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# =============================================================================
# 文件上传配置
# =============================================================================
UPLOAD_MAX_SIZE=50MB
UPLOAD_PATH=/app/uploads
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xlsx,ppt,pptx,txt,md

# =============================================================================
# 服务器配置
# =============================================================================
SERVER_PORT=8080

# =============================================================================
# 可信代理配置（客户端 IP 解析）
# =============================================================================
# 限流器据此从 X-Forwarded-For 解析真实客户端 IP（仅在 TCP 对端是可信代理时才信任 XFF）。
#   - 留空 = 直连模式，忽略所有 XFF（适用于无反向代理、IDE 直跑场景，最安全）
#   - Docker bridge 网络下 Nginx 容器 IP 通常落在 172.16.0.0/12 内
# 支持精确 IP（127.0.0.1、::1）与 IPv4 CIDR（172.16.0.0/12），逗号分隔。
TRUSTED_PROXIES=172.16.0.0/12,127.0.0.1,::1

# =============================================================================
# 初始用户配置
# =============================================================================
# 仅在首次启动（用户表为空）时创建这些用户
# ⚠️ 生产环境务必设置为强密码
INIT_ADMIN_PASSWORD=admin123
INIT_EDITOR_PASSWORD=editor123
INIT_USER_PASSWORD=user123

# =============================================================================
# Swagger API 文档
# =============================================================================
# 生产环境务必关闭（false），开发环境开启（true）
SWAGGER_ENABLED=false

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN
