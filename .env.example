# =============================================================================
# 环境变量配置模板
# =============================================================================
# 使用说明：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 修改下面的值为你的实际配置
#   3. .env 已加入 .gitignore，不会被提交到代码仓库
# =============================================================================

# 应用配置
APP_NAME=KnowledgeBase
APP_ENV=production
APP_DEBUG=false

# =============================================================================
# Jasypt 密码加密配置
# =============================================================================
# 主密钥：用于解密 application.yml 中 ENC() 包裹的配置值
# ⚠️ 务必设置为自己的密钥，且不要提交到代码仓库
# 加密工具用法（在 backend 目录下执行）：
#   JAVA_HOME=$(/usr/libexec/java_home -v 17) mvn -q dependency:build-classpath -Dmdep.outputFile=/tmp/kb-cp.txt
#   $JAVA_HOME/bin/java -cp "$(cat /tmp/kb-cp.txt):target/classes" \
#     -Djasypt.encryptor.password=<你的主密钥> \
#     com.geekyous.kb.utils.JasyptEncryptUtil encrypt <要加密的明文>
JASYPT_ENCRYPTOR_PASSWORD=your-master-key-change-me

# =============================================================================
# 数据库配置
# =============================================================================
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=knowledge_base
DB_USERNAME=kb_user
# 数据库密码支持两种格式：
#   明文：直接填写密码
#   密文：使用 Jasypt 加密后填写 ENC(密文)
DB_PASSWORD=ENC(replace-with-your-encrypted-password)
DB_ROOT_PASSWORD=root_password

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# Redis 密码（如启用认证，建议使用 ENC() 加密）
REDIS_PASSWORD=

# =============================================================================
# Elasticsearch 配置
# =============================================================================
ES_HOST=elasticsearch
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=

# =============================================================================
# JWT 配置
# =============================================================================
# JWT 密钥（建议使用 ENC() 加密）
JWT_SECRET=your-secret-key-here-please-change-in-production
JWT_EXPIRATION=86400

# =============================================================================
# AI 服务配置
# =============================================================================
AI_SERVICE_URL=http://ai-service:8000
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM 配置
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2
OLLAMA_EMBED_MODEL=nomic-embed-text
MOCK_MODE=false

# =============================================================================
# Qdrant 配置
# =============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# =============================================================================
# 文件上传配置
# =============================================================================
UPLOAD_MAX_SIZE=50MB
UPLOAD_PATH=/app/uploads
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xlsx,ppt,pptx,txt,md

# =============================================================================
# 服务器配置
# =============================================================================
SERVER_PORT=8080

# =============================================================================
# 初始用户配置
# =============================================================================
# 仅在首次启动（用户表为空）时创建这些用户
# 生产环境务必设置为强密码，不要使用默认值
INIT_ADMIN_PASSWORD=admin123
INIT_EDITOR_PASSWORD=admin123
INIT_USER_PASSWORD=admin123

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN
