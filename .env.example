# 应用配置
APP_NAME=KnowledgeBase
APP_ENV=production
APP_DEBUG=false

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=knowledge_base
DB_USERNAME=kb_user
DB_PASSWORD=kb_password
DB_ROOT_PASSWORD=root_password

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch 配置
ES_HOST=elasticsearch
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=

# JWT 配置
JWT_SECRET=your-secret-key-here-please-change-in-production
JWT_EXPIRATION=86400

# AI 服务配置
AI_SERVICE_URL=http://ai-service:8000
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Qdrant 配置
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# 文件上传配置
UPLOAD_MAX_SIZE=50MB
UPLOAD_PATH=/app/uploads
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xlsx,ppt,pptx,txt,md

# 服务器配置
SERVER_PORT=8080

# 日志配置
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN
